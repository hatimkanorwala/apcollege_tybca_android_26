<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:theme="@style/Base.Theme.AP_TYBCA_SEM6"
    tools:context=".profile">
    <TextView
        android:id="@+id/profile_tv_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="User Profile"
        android:textAlignment="center"
        android:textSize="20dp"
        android:layout_marginTop="10dp"
        android:textColor="@color/black"
        />
    <LinearLayout
        android:id="@+id/profile_ll_viewProfile"
        android:layout_below="@id/profile_tv_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:visibility="gone"
        android:orientation="vertical">
        <TableLayout
            android:id="@+id/table_profile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/table_background"
            android:padding="16dp"
            android:stretchColumns="1">
            <!-- Row 1: Username -->
            <TableRow
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp">
                <TextView
                    android:id="@+id/profile_label_tv_username"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Username"
                    android:textColor="#666666"
                    android:textSize="16sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/profile_value_tv_username"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:paddingStart="24dp"
                    android:text="Username"
                    android:textSize="16sp" />
            </TableRow>
            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E0E0E0" />
            <!-- Row 2: Email -->
            <TableRow
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp">
                <TextView
                    android:id="@+id/profile_label_tv_email"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Email"
                    android:textColor="#666666"
                    android:textSize="16sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/profile_value_tv_email"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:paddingStart="24dp"
                    android:text="example@example.com"
                    android:textSize="16sp" />
            </TableRow>
            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E0E0E0" />
            <!-- Row 3: Contact -->
            <TableRow
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp">

                <TextView
                    android:id="@+id/profile_label_tv_contact"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Contact"
                    android:textColor="#666666"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/profile_value_tv_contact"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:paddingStart="24dp"
                    android:text="+91 000 000 000 0"
                    android:textSize="16sp" />

            </TableRow>
        </TableLayout>
        <Button
            android:id="@+id/profile_btn_showEditSection"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Edit Data"
            android:layout_gravity="center"
            android:onClick="showProfileEditSection"
            />
    </LinearLayout>
    <LinearLayout
        android:id="@+id/profile_ll_editProfile"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="10dp"
        android:background="@drawable/table_background"
        android:layout_below="@id/profile_tv_header"
        android:padding="5dp"
        android:layout_margin="10dp"
        android:visibility="visible"
        >
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/profile_etl_username"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:errorEnabled="true">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/profile_et_username"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/enterUsername"
                android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/profile_etl_email"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:errorEnabled="true">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/profile_et_email"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/enterEmail"
                android:inputType="textEmailAddress" />
        </com.google.android.material.textfield.TextInputLayout>
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/profile_etl_contact"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:errorEnabled="true"
            app:counterMaxLength="10"
            app:counterEnabled="true">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/profile_et_contact"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/enterContact"
                android:maxLength="10"
                android:inputType="number" />
        </com.google.android.material.textfield.TextInputLayout>
        <Button
            android:id="@+id/profile_btn_editProfile"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/newregistration_etl_contact"
            android:layout_gravity="center"
            android:drawableLeft="@drawable/edit_icon"
            android:text="Edit Profile"
            android:onClick="btnEditProfile"
            />
        <Button
            android:id="@+id/profile_btn_cancelEditSection"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/newregistration_etl_contact"
            android:layout_gravity="center"
            android:drawableLeft="@drawable/error_icon"
            android:text="Cancel"
            android:onClick="btnCancelEditSection"
            />
    </LinearLayout>

</RelativeLayout>